{
  "request_timeout": "90s",
  "natural_memory": {
    "enabled": true,
    "extraction_provider": "openai-main",
    "extraction_model": "gpt-4.1-mini",
    "embedding_provider": "openai-main",
    "extraction_timeout": "30s",
    "extraction_max_input_runes": 4000,
    "context_window_size": 5,
    "synthesis_match_limit": 5,
    "consolidation_interval": "1h",
    "consolidation_provider": "openai-main",
    "consolidation_model": "gpt-4.1-mini",
    "consolidation_timeout": "60s",
    "max_memories_per_scope": 200,
    "decay_factor": 0.995,
    "min_importance": 3,
    "duplicate_similarity_threshold": 0.85,
    "reflection_min_source_memories": 8,
    "reflection_source_limit": 20,
    "reflection_max_generated": 3,
    "retrieval_planning_enabled": true,
    "retrieval_planning_timeout": "10s",
    "cluster_min_size": 3,
    "cluster_similarity_threshold": 0.80,
    "cluster_temporal_weight": 0.3
  },
  "providers": {
    "openai-main": {
      "type": "openai",
      "api_key": "sk-REPLACE_ME",
      "base_url": "https://api.openai.com/v1",
      "embedding_model": "text-embedding-3-small",
      "embedding_dimensions": 512,
      "openai": {
        "organization": "",
        "project": "",
        "max_retries": 2
      }
    },
    "gemini-main": {
      "type": "gemini",
      "api_key": "gm-REPLACE_ME",
      "base_url": "https://generativelanguage.googleapis.com",
      "embedding_model": "gemini-embedding-001",
      "embedding_dimensions": 512,
      "gemini": {
        "api_version": "v1beta",
        "google_search": true,
        "url_context": true,
        "include_thoughts": false,
        "thinking_level": "medium",
        "response_mime_type": "application/json",
        "safety_filter_off": false
      }
    }
  },
  "agents": [
    {
      "name": "Otogi",
      "aliases": ["Oto"],
      "description": "General assistant persona",
      "provider": "openai-main",
      "embedding_provider": "openai-main",
      "model": "gpt-5-mini",
      "system_prompt_template": "You are {{.AgentName}}. Current UTC time: {{.DateTimeUTC}}.",
      "semantic_memory": {
        "enabled": true,
        "max_retrieved_memories": 5,
        "min_memory_similarity": 0.3,
        "max_memory_runes": 2000
      },
      "template_variables": {
        "locale": "en-US"
      },
      "context": {
        "reply_chain_max_messages": 12,
        "leading_context_messages": 4,
        "leading_context_max_age": "15m",
        "max_context_runes": 12000,
        "max_message_runes": 1600,
        "quote_reply_depth": 2
      },
      "image_inputs": {
        "enabled": true,
        "max_images": 3,
        "max_image_bytes": 10485760,
        "max_total_bytes": 20971520,
        "detail": "auto"
      },
      "request_timeout": "90s",
      "max_output_tokens": 512,
      "temperature": 0.4
    },
    {
      "name": "OtogiGemini",
      "aliases": ["OtoGemini"],
      "description": "Gemini assistant persona",
      "provider": "gemini-main",
      "embedding_provider": "gemini-main",
      "model": "gemini-2.5-flash",
      "system_prompt_template": "You are {{.AgentName}}. Current UTC time: {{.DateTimeUTC}}.",
      "semantic_memory": {
        "enabled": true,
        "max_retrieved_memories": 5,
        "min_memory_similarity": 0.3,
        "max_memory_runes": 2000
      },
      "context": {
        "reply_chain_max_messages": 12,
        "leading_context_messages": 4,
        "leading_context_max_age": "15m",
        "max_context_runes": 12000,
        "max_message_runes": 1600,
        "quote_reply_depth": 2
      },
      "image_inputs": {
        "enabled": true,
        "max_images": 3,
        "max_image_bytes": 10485760,
        "max_total_bytes": 20971520,
        "detail": "auto"
      },
      "request_timeout": "90s",
      "max_output_tokens": 512,
      "temperature": 0.4,
      "request_metadata": {
        "gemini.google_search": "false",
        "gemini.url_context": "false",
        "gemini.include_thoughts": "false",
        "gemini.thinking_level": "high",
        "gemini.response_mime_type": "text/plain"
      },
      "sub_agents": [
        {
          "name": "web_search",
          "description": "Search the web for current information using Google Search. Use this when you need up-to-date facts, news, or real-time data.",
          "provider": "gemini-main",
          "model": "gemini-2.5-flash",
          "system_prompt": "You are a web search assistant. Search for the requested information and provide a concise, factual summary of what you find. Include relevant sources when available.",
          "max_output_tokens": 4096,
          "temperature": 0.3,
          "request_metadata": {
            "gemini.google_search": "true"
          },
          "parameters": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string",
                "description": "The search query to look up"
              }
            },
            "required": ["query"],
            "additionalProperties": false
          },
          "prompt_template": "{{.query}}"
        },
        {
          "name": "read_url",
          "description": "Read and analyze the content of a specific URL. Use this when you need to examine a webpage or document at a known URL.",
          "provider": "gemini-main",
          "model": "gemini-2.5-flash",
          "system_prompt": "You are a URL content reader. Fetch and analyze the content at the given URL. Provide a clear summary of the page content, focusing on the most relevant information.",
          "max_output_tokens": 4096,
          "temperature": 0.2,
          "request_metadata": {
            "gemini.url_context": "true"
          },
          "parameters": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "description": "The URL to read and analyze"
              },
              "question": {
                "type": "string",
                "description": "Optional specific question about the URL content"
              }
            },
            "required": ["url"],
            "additionalProperties": false
          },
          "prompt_template": "Read this URL: {{.url}}{{if .question}}\n\nSpecifically answer: {{.question}}{{end}}"
        }
      ]
    }
  ]
}
